# Scan and report git repo status; prints results, returns 0 if all clean
scan_repos() {
  local search_dir
  search_dir="$(cd "$1" && pwd)"

  local tmpfile countsfile
  tmpfile=$(mktemp)
  countsfile=$(mktemp)
  echo "0 0 0" > "$countsfile"

  local spinner_chars=('⠋' '⠙' '⠹' '⠸' '⠼' '⠴' '⠦' '⠧' '⠇' '⠏')
  printf "\033[?25l"  # hide cursor during scan

  # Spinner updates the scanning line in-place; hint stays on the line below
  (
    local i=0
    while true; do
      printf "\r${BLUE}=== Scanning: $search_dir ${BRIGHT_PINK}${spinner_chars[$((i % ${#spinner_chars[@]}))]}\033[0m${BLUE} ===${NC}\n  ${YELLOW}Ctrl+C to abort${NC}\033[1A"
      i=$((i + 1))
      sleep 0.1
    done
  ) &
  local spinner_pid=$!

  # Run the scan in a background subshell.
  # stdin is closed (/dev/null) so git processes cannot steal terminal input.
  (
    local _total=0 _dirty=0 _clean=0
    while IFS= read -r gitdir; do
      local repo_dir mod issues
      repo_dir=$(dirname "$gitdir")
      _total=$((_total + 1))
      mod=0
      issues=""

      git -C "$repo_dir" fetch --quiet 2>/dev/null || true
      local status_out
      status_out=$(git -C "$repo_dir" status 2>/dev/null)

      if echo "$status_out" | grep -q "modified:";            then mod=1; issues="${issues}  ${RED}✗ Modified files${NC}\n"; fi
      if echo "$status_out" | grep -q "Untracked files:";     then mod=1; issues="${issues}  ${RED}✗ Untracked files${NC}\n"; fi
      if echo "$status_out" | grep -q "Your branch is ahead"; then mod=1; issues="${issues}  ${RED}✗ Unpushed commits${NC}\n"; fi
      if echo "$status_out" | grep -q "Your branch is behind";then mod=1; issues="${issues}  ${YELLOW}⚠ Behind remote (pull needed)${NC}\n"; fi
      if echo "$status_out" | grep -q "Changes to be committed:"; then mod=1; issues="${issues}  ${YELLOW}⚠ Staged but uncommitted changes${NC}\n"; fi

      if [ "$mod" -eq 1 ]; then
        _dirty=$((_dirty + 1))
        { echo -e "${BRIGHT_PINK}▶ $repo_dir${NC}"; echo -e "$issues"; } >> "$tmpfile"
      else
        _clean=$((_clean + 1))
        echo -e "${GREEN}✓${NC} $repo_dir" >> "$tmpfile"
      fi
      echo "$_total $_dirty $_clean" > "$countsfile"
    done < <(find "$search_dir" -type d -name ".git" 2>/dev/null | sort)
  ) </dev/null &
  local scan_pid=$!

  wait "$scan_pid" 2>/dev/null

  # Kill spinner, overwrite spinner line, clear hint line below, restore cursor
  kill "$spinner_pid" 2>/dev/null
  wait "$spinner_pid" 2>/dev/null
  printf "\r\033[2K${BLUE}=== Scanning: $search_dir ${GREEN}✓${NC}${BLUE} ===${NC}\n\033[2K\033[?25h"

  # Read counts written by the subshell
  local total dirty clean
  read -r total dirty clean < "$countsfile"
  rm -f "$countsfile"

  # Dump buffered results
  cat "$tmpfile"
  rm -f "$tmpfile"

  echo -e "${CYAN}─────────────────────────────────────────${NC}"
  echo -e "  Total repos : ${BOLD}$total${NC}"
  echo -e "  ${GREEN}Clean       : $clean${NC}"
  if [ "$dirty" -gt 0 ]; then
    echo -e "  ${RED}Need attention: $dirty${NC}"
  else
    echo -e "  ${GREEN}Need attention: 0${NC}"
  fi
  echo -e "${CYAN}─────────────────────────────────────────${NC}"
}

do_scan_default() {
  if [ "$SHOW_DIRTY_ONLY" -eq 1 ]; then
    do_scan_dirty_only_internal "$SCAN_DIR"
  else
    scan_repos "$SCAN_DIR"
  fi
  echo ""
  read -rsn1 -p "Press any key to continue..."
}

do_scan_custom() {
  echo ""
  read -r -p "$(echo -e "${BRIGHT_PINK}Enter path to scan:${NC} ")" custom_path
  if [ -z "$custom_path" ]; then
    print_error "No path entered."
    sleep 1
    return
  fi
  # Expand ~ manually
  custom_path="${custom_path/#\~/$HOME}"
  if [ ! -d "$custom_path" ]; then
    print_error "Directory not found: $custom_path"
    sleep 1
    return
  fi
  SCAN_DIR="$custom_path"
  if [ "$SHOW_DIRTY_ONLY" -eq 1 ]; then
    do_scan_dirty_only_internal "$SCAN_DIR"
  else
    scan_repos "$SCAN_DIR"
  fi
  echo ""
  read -rsn1 -p "Press any key to continue..."
}

