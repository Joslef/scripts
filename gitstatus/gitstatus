  echo -e "    ${BRIGHT_PINK}${ITALIC}║${NC}  ${HOT_PINK}╚════██║   ██║   ██╔══██║   ██║   ██║   ██║╚════██║${NC}  ${BRIGHT_PINK}${ITALIC}║${NC}"
