  cat "$tmpfile"
  rm -f "$tmpfile"

  echo -e "${CYAN}─────────────────────────────────────────${NC}"
  echo -e "  Total repos : ${BOLD}$total${NC}"
  echo -e "  ${GREEN}Clean       : $clean${NC}"
  if [ "$dirty" -gt 0 ]; then
    echo -e "  ${RED}Need attention: $dirty${NC}"
  else
    echo -e "  ${GREEN}Need attention: 0${NC}"
  fi
  echo -e "${CYAN}─────────────────────────────────────────${NC}"
}

show_menu() {
  clear
  print_banner
  # Dynamic spacing for directory path line
  current_dir="$(pwd)"
  dir_padding=$((55 - 2 - ${#current_dir}))
  echo -e "  ${CYAN}* ${CYAN}${ITALIC}╔═══════════════════════════════════════════════════════╗${NC}${CYAN} *"
  echo -e "    ${CYAN}${ITALIC}║${NC} ${BRIGHT_PINK}* Git Repository Status Checker *${NC}                     ${CYAN}${ITALIC}║${NC}"
  echo -e "    ${CYAN}${ITALIC}╠═══════════════════════════════════════════════════════╣${NC}"
  echo -e "    ${CYAN}${ITALIC}║${NC}                                                       ${CYAN}${ITALIC}║${NC}"
  printf "    ${CYAN}${ITALIC}║${NC}  ${YELLOW}%s${NC}%-*s${CYAN}${ITALIC}║${NC}\n" "$current_dir" "$dir_padding" ""
  echo -e "    ${CYAN}${ITALIC}║${NC}                                                       ${CYAN}${ITALIC}║${NC}"
  echo -e "    ${CYAN}${ITALIC}║${NC}  ${PINK}>${NC} ${GREEN}1)${NC} Scan all repos (current path)                   ${CYAN}${ITALIC}║${NC}"
  echo -e "    ${CYAN}${ITALIC}║${NC}  ${PINK}>${NC} ${GREEN}2)${NC} Scan repos (custom path)                        ${CYAN}${ITALIC}║${NC}"
  echo -e "    ${CYAN}${ITALIC}║${NC}                                                       ${CYAN}${ITALIC}║${NC}"
  # Dynamic display for option 3 based on SHOW_DIRTY_ONLY state
  if [ "$SHOW_DIRTY_ONLY" -eq 1 ]; then
    filter_status="${GREEN}[X]${NC}"
  else
    filter_status="${GREEN}[ ]${NC}"
  fi
  printf "    ${CYAN}${ITALIC}║${NC}  ${PINK}>${NC} ${GREEN}3)${NC} %b Show dirty repos only                       ${CYAN}${ITALIC}║${NC}\n" "$filter_status"
  echo -e "    ${CYAN}${ITALIC}║${NC}                                                       ${CYAN}${ITALIC}║${NC}"
  echo -e "    ${CYAN}${ITALIC}║${NC}  ${PINK}>${NC} ${RED}0)${NC} Exit                                            ${CYAN}${ITALIC}║${NC}"
  echo -e "    ${CYAN}${ITALIC}║${NC}                                                       ${CYAN}${ITALIC}║${NC}"
  echo -e "  ${CYAN}* ${CYAN}${ITALIC}╚═══════════════════════════════════════════════════════╝${NC}${CYAN} *${NC}"
  echo ""
}

main() {
  # Default scan dir: first argument or current directory
  SCAN_DIR="${1:-.}"
  # Expand ~ if passed as argument
  SCAN_DIR="${SCAN_DIR/#\~/$HOME}"

  # Non-interactive mode: --scan or -s flag just runs and exits
  if [ "${1:-}" == "--scan" ] || [ "${1:-}" == "-s" ]; then
    SCAN_DIR="${2:-.}"
    scan_repos "$SCAN_DIR"
    exit 0
  fi

  while true; do
    show_menu
    echo -ne "${BRIGHT_PINK}Select option [0-3]:${NC} "
    read -rsn1 choice
    echo ""
    case $choice in
      1) do_scan_default ;;
      2) do_scan_custom ;;
      3)
        SHOW_DIRTY_ONLY=$((1 - SHOW_DIRTY_ONLY))
        # Update only the X/space in the middle of the checkbox
        printf "\033[6A\033[13G"  # Move up 6 lines, move to middle of checkbox
        if [ "$SHOW_DIRTY_ONLY" -eq 1 ]; then
          printf "X"
        else
          printf " "
        fi
        printf "\033[5B"  # Move down 5 lines back to prompt
        ;;
      0)
        echo -e "\n${PINK}*${NC} ${GREEN}Goodbye!${NC} ${PINK}*${NC}\n"
        exit 0
        ;;
      *)
        print_error "Invalid option"
        sleep 1
        ;;
    esac
  done
}

main "$@"
