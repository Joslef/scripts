  local search_dir
  search_dir="$(cd "$1" && pwd)"

  local tmpfile countsfile
  tmpfile=$(mktemp)
  countsfile=$(mktemp)
  echo "0 0 0" > "$countsfile"

  local spinner_chars=('⠋' '⠙' '⠹' '⠸' '⠼' '⠴' '⠦' '⠧' '⠇' '⠏')
  printf "\033[?25l"  # hide cursor during scan

  # Spinner updates the scanning line in-place; hint stays on the line below
  (
    local i=0
    while true; do
      printf "\r${BLUE}=== Dirty repos in: $search_dir ${BRIGHT_PINK}${spinner_chars[$((i % ${#spinner_chars[@]}))]}\033[0m${BLUE} ===${NC}\n  ${YELLOW}Ctrl+C to abort${NC}\033[1A"
      i=$((i + 1))
      sleep 0.1
    done
  ) &
  local spinner_pid=$!

  # Run the scan in a background subshell.
