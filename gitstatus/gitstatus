#!/bin/bash

set -uo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
ITALIC='\033[3m'
NC='\033[0m'

PINK='\033[38;5;198m'
BRIGHT_PINK='\033[38;5;201m'
HOT_PINK='\033[38;5;205m'

# Abort cleanly on Ctrl+C: kill all subshells in this process group, then exit
trap 'trap "" TERM; printf "\r\033[2K${BLUE}===${NC} ${RED}Aborted${NC} ${BLUE}===${NC}\n\033[2K\033[?25h\n"; kill -- -$$ 2>/dev/null; exit 130' INT

# Filter mode: 0 = show all repos, 1 = show dirty only
SHOW_DIRTY_ONLY=0

print_header() {
  echo -e "\n${BLUE}=== $1 ===${NC}"
}

print_success() {
  echo -e "${GREEN}✓ $1${NC}"
}

print_warning() {
  echo -e "${YELLOW}⚠ $1${NC}"
}

print_error() {
  echo -e "${RED}✗ $1${NC}"
}

# Spinner animation function
spinner() {
  local pid=$1
  local delay=0.1
  local spinner_chars=('⠋' '⠙' '⠹' '⠸' '⠼' '⠴' '⠦' '⠧' '⠇' '⠏')
  local i=0

  while kill -0 $pid 2>/dev/null; do
    printf "\r${BRIGHT_PINK}${spinner_chars[$((i % ${#spinner_chars[@]}))]}\033[0m"
    i=$((i + 1))
    sleep $delay
  done
  printf "\r \r"  # Clear the spinner
}

