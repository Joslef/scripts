#!/bin/bash

set -uo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
ITALIC='\033[3m'
NC='\033[0m'

PINK='\033[38;5;198m'
BRIGHT_PINK='\033[38;5;201m'
HOT_PINK='\033[38;5;205m'

# Abort cleanly on Ctrl+C: kill all subshells in this process group, then exit
trap 'trap "" TERM; printf "\r\033[2K${BLUE}===${NC} ${RED}Aborted${NC} ${BLUE}===${NC}\n\033[2K\033[?25h\n"; kill -- -$$ 2>/dev/null; exit 130' INT

# Filter mode: 0 = show all repos, 1 = show dirty only
SHOW_DIRTY_ONLY=0

# Braille spinner characters (shared global)
SPINNER_CHARS=('⠋' '⠙' '⠹' '⠸' '⠼' '⠴' '⠦' '⠧' '⠇' '⠏')

# Strip control characters from user-supplied paths to prevent ANSI injection
safe_path() { printf '%s' "$1" | tr -d '\001-\037\177'; }

print_header() {
  echo -e "\n${BLUE}=== $1 ===${NC}"
}

print_success() {
  echo -e "${GREEN}✓ $1${NC}"
}

print_warning() {
  echo -e "${YELLOW}⚠ $1${NC}"
}

print_error() {
  echo -e "${RED}✗ $1${NC}"
}

print_banner() {
  echo -e "${PINK}"
  echo -e "  ${BRIGHT_PINK}* ${ITALIC}╔═══════════════════════════════════════════════════════╗${NC}${BRIGHT_PINK} *"
  echo -e "    ${BRIGHT_PINK}${ITALIC}║${NC}                                                       ${BRIGHT_PINK}${ITALIC}║${NC}"
  echo -e "    ${BRIGHT_PINK}${ITALIC}║${NC}  ${BRIGHT_PINK} ██████╗ ██╗████████╗${NC}                                ${BRIGHT_PINK}${ITALIC}║${NC}"
  echo -e "    ${BRIGHT_PINK}${ITALIC}║${NC}  ${BRIGHT_PINK}██╔════╝ ██║╚══██╔══╝${NC}                                ${BRIGHT_PINK}${ITALIC}║${NC}"
  echo -e "    ${BRIGHT_PINK}${ITALIC}║${NC}  ${BRIGHT_PINK}██║  ███╗██║   ██║${NC}                                   ${BRIGHT_PINK}${ITALIC}║${NC}"
  echo -e "    ${BRIGHT_PINK}${ITALIC}║${NC}  ${BRIGHT_PINK}██║   ██║██║   ██║${NC}                                   ${BRIGHT_PINK}${ITALIC}║${NC}"
  echo -e "    ${BRIGHT_PINK}${ITALIC}║${NC}  ${BRIGHT_PINK}╚██████╔╝██║   ██║${NC}                                   ${BRIGHT_PINK}${ITALIC}║${NC}"
  echo -e "    ${BRIGHT_PINK}${ITALIC}║${NC}  ${BRIGHT_PINK} ╚═════╝ ╚═╝   ╚═╝${NC}                                   ${BRIGHT_PINK}${ITALIC}║${NC}"
  echo -e "    ${BRIGHT_PINK}${ITALIC}║${NC}                                                       ${BRIGHT_PINK}${ITALIC}║${NC}"
  echo -e "    ${BRIGHT_PINK}${ITALIC}║${NC}  ${HOT_PINK}███████╗████████╗ █████╗ ████████╗██╗   ██╗███████╗${NC}  ${BRIGHT_PINK}${ITALIC}║${NC}"
  echo -e "    ${BRIGHT_PINK}${ITALIC}║${NC}  ${HOT_PINK}██╔════╝╚══██╔══╝██╔══██╗╚══██╔══╝██║   ██║██╔════╝${NC}  ${BRIGHT_PINK}${ITALIC}║${NC}"
  echo -e "    ${BRIGHT_PINK}${ITALIC}║${NC}  ${HOT_PINK}███████╗   ██║   ███████║   ██║   ██║   ██║███████╗${NC}  ${BRIGHT_PINK}${ITALIC}║${NC}"
  echo -e "    ${BRIGHT_PINK}${ITALIC}║${NC}  ${HOT_PINK}╚════██║   ██║   ██╔══██║   ██║   ██║   ██║╚════██║${NC}  ${BRIGHT_PINK}${ITALIC}║${NC}"
  echo -e "    ${BRIGHT_PINK}${ITALIC}║${NC}  ${HOT_PINK}███████║   ██║   ██║  ██║   ██║   ╚██████╔╝███████║${NC}  ${BRIGHT_PINK}${ITALIC}║${NC}"
  echo -e "    ${BRIGHT_PINK}${ITALIC}║${NC}  ${HOT_PINK}╚══════╝   ╚═╝   ╚═╝  ╚═╝   ╚═╝    ╚═════╝╚══════╝${NC}   ${BRIGHT_PINK}${ITALIC}║${NC}"
  echo -e "    ${BRIGHT_PINK}${ITALIC}║${NC}                                                       ${BRIGHT_PINK}${ITALIC}║${NC}"
  echo -e "  ${BRIGHT_PINK}* ${ITALIC}╚═══════════════════════════════════════════════════════╝${NC}${BRIGHT_PINK} *${NC}"
  echo ""
}

# _scan_impl <dir> <mode>
#   mode="all"   — report clean and dirty repos
#   mode="dirty" — report dirty repos only
_scan_impl() {
  local search_dir mode
  search_dir="$(cd "$1" && pwd)"
  mode="$2"

  local tmpfile countsfile
  tmpfile=$(mktemp)
  countsfile=$(mktemp)
  echo "0 0 0" > "$countsfile"

  # Remove temp files on exit (also covers Ctrl+C via exit 130 from the INT trap)
  trap "rm -f \"$tmpfile\" \"$countsfile\"" EXIT

  local safe_dir
  safe_dir="$(safe_path "$search_dir")"

  local header_text
  if [ "$mode" = "dirty" ]; then
    header_text="Dirty repos in:"
  else
    header_text="Scanning:"
  fi

  printf "\033[?25l"  # hide cursor during scan

  # Spinner updates the scanning line in-place; hint stays on the line below
  (
    local i=0
    while true; do
      printf "\r${BLUE}=== %s %s ${BRIGHT_PINK}%s\033[0m${BLUE} ===${NC}\n  ${YELLOW}Ctrl+C to abort${NC}\033[1A" \
        "$header_text" "$safe_dir" "${SPINNER_CHARS[$((i % ${#SPINNER_CHARS[@]}))]}"
      i=$((i + 1))
      sleep 0.1
    done
  ) &
  local spinner_pid=$!

  # Combined fetch + status subshell (stdin closed so git can't steal terminal)
  (
    # Prefetch pass — all repos fetched in parallel
    while IFS= read -r gitdir; do
      env -u GIT_DIR -u GIT_WORK_TREE git -C "$(dirname "$gitdir")" fetch --quiet 2>/dev/null &
    done < <(find "$search_dir" -type d -name ".git" 2>/dev/null)
    wait

    # Status pass — no network I/O
    _total=0; _dirty=0; _clean=0
    while IFS= read -r gitdir; do
      repo_dir=$(dirname "$gitdir")
      safe_repo="$(safe_path "$repo_dir")"
      _total=$((_total + 1))
      mod=0
      issues=""

      status_out=$(env -u GIT_DIR -u GIT_WORK_TREE git -C "$repo_dir" status 2>/dev/null)

      [[ "$status_out" == *"modified:"*               ]] && { mod=1; issues="${issues}  ${RED}✗ Modified files${NC}\n"; }
      [[ "$status_out" == *"Untracked files:"*        ]] && { mod=1; issues="${issues}  ${RED}✗ Untracked files${NC}\n"; }
      [[ "$status_out" == *"Your branch is ahead"*    ]] && { mod=1; issues="${issues}  ${RED}✗ Unpushed commits${NC}\n"; }
      [[ "$status_out" == *"Your branch is behind"*   ]] && { mod=1; issues="${issues}  ${YELLOW}⚠ Behind remote (pull needed)${NC}\n"; }
      [[ "$status_out" == *"Changes to be committed:"* ]] && { mod=1; issues="${issues}  ${YELLOW}⚠ Staged but uncommitted changes${NC}\n"; }

      if [ "$mod" -eq 1 ]; then
        _dirty=$((_dirty + 1))
        { printf "${BRIGHT_PINK}▶ %s${NC}\n" "$safe_repo"; printf "%b" "$issues"; } >> "$tmpfile"
      elif [ "$mode" = "all" ]; then
        _clean=$((_clean + 1))
        printf "${GREEN}✓${NC} %s\n" "$safe_repo" >> "$tmpfile"
      else
        _clean=$((_clean + 1))
      fi
      echo "$_total $_dirty $_clean" > "$countsfile"
    done < <(find "$search_dir" -type d -name ".git" 2>/dev/null | sort)
  ) </dev/null &
  local scan_pid=$!

  wait "$scan_pid" 2>/dev/null

  # Kill spinner, overwrite spinner line, clear hint line below, restore cursor
  kill "$spinner_pid" 2>/dev/null
  wait "$spinner_pid" 2>/dev/null
  printf "\r\033[2K${BLUE}=== %s %s ${GREEN}✓${NC}${BLUE} ===${NC}\n\033[2K\033[?25h" "$header_text" "$safe_dir"

  # Read counts written by the subshell
  local total dirty clean
  read -r total dirty clean < "$countsfile"
  rm -f "$countsfile"

  # Dump buffered results
  cat "$tmpfile"
  rm -f "$tmpfile"

  echo -e "${CYAN}─────────────────────────────────────────${NC}"
  echo -e "  Total repos : ${BOLD}$total${NC}"
  echo -e "  ${GREEN}Clean       : $clean${NC}"
  if [ "$dirty" -gt 0 ]; then
    echo -e "  ${RED}Need attention: $dirty${NC}"
  else
    echo -e "  ${GREEN}Need attention: 0${NC}"
  fi
  echo -e "${CYAN}─────────────────────────────────────────${NC}"
}

scan_repos()                  { _scan_impl "$1" "all";   }
do_scan_dirty_only_internal() { _scan_impl "$1" "dirty"; }

do_scan_default() {
  if [ "$SHOW_DIRTY_ONLY" -eq 1 ]; then
    do_scan_dirty_only_internal "$SCAN_DIR"
  else
    scan_repos "$SCAN_DIR"
  fi
  echo ""
  read -rsn1 -p "Press any key to continue..." || true
}

do_scan_custom() {
  echo ""
  read -r -p "$(echo -e "${BRIGHT_PINK}Enter path to scan:${NC} ")" custom_path || true
  if [ -z "${custom_path:-}" ]; then
    print_error "No path entered."
    sleep 1
    return
  fi
  # Expand ~ manually
  custom_path="${custom_path/#\~/$HOME}"
  if [ ! -d "$custom_path" ]; then
    print_error "Directory not found: $custom_path"
    sleep 1
    return
  fi
  if [ "$SHOW_DIRTY_ONLY" -eq 1 ]; then
    do_scan_dirty_only_internal "$custom_path"
  else
    scan_repos "$custom_path"
  fi
  echo ""
  read -rsn1 -p "Press any key to continue..." || true
}

show_menu() {
  clear
  print_banner

  # Resolve SCAN_DIR to absolute path for display
  local current_dir
  current_dir="$(cd "$SCAN_DIR" 2>/dev/null && pwd)" || current_dir="$SCAN_DIR"

  # Clamp display path to 53 chars with leading ellipsis
  local max_len=53 display_dir dir_padding
  if [ "${#current_dir}" -gt "$max_len" ]; then
    display_dir="...${current_dir: -$((max_len - 3))}"
  else
    display_dir="$current_dir"
  fi
  dir_padding=$(( max_len - ${#display_dir} ))
  [ "$dir_padding" -lt 0 ] && dir_padding=0

  echo -e "  ${CYAN}* ${CYAN}${ITALIC}╔═══════════════════════════════════════════════════════╗${NC}${CYAN} *"
  echo -e "    ${CYAN}${ITALIC}║${NC} ${BRIGHT_PINK}* Git Repository Status Checker *${NC}                     ${CYAN}${ITALIC}║${NC}"
  echo -e "    ${CYAN}${ITALIC}╠═══════════════════════════════════════════════════════╣${NC}"
  echo -e "    ${CYAN}${ITALIC}║${NC}                                                       ${CYAN}${ITALIC}║${NC}"
  printf "    ${CYAN}${ITALIC}║${NC}  ${YELLOW}%s${NC}%-*s${CYAN}${ITALIC}║${NC}\n" "$display_dir" "$dir_padding" ""
  echo -e "    ${CYAN}${ITALIC}║${NC}                                                       ${CYAN}${ITALIC}║${NC}"
  echo -e "    ${CYAN}${ITALIC}║${NC}  ${PINK}>${NC} ${GREEN}1)${NC} Scan all repos (current path)                   ${CYAN}${ITALIC}║${NC}"
  echo -e "    ${CYAN}${ITALIC}║${NC}  ${PINK}>${NC} ${GREEN}2)${NC} Scan repos (custom path)                        ${CYAN}${ITALIC}║${NC}"
  echo -e "    ${CYAN}${ITALIC}║${NC}                                                       ${CYAN}${ITALIC}║${NC}"
  # Dynamic display for option 3 based on SHOW_DIRTY_ONLY state
  local filter_status
  if [ "$SHOW_DIRTY_ONLY" -eq 1 ]; then
    filter_status="${GREEN}[X]${NC}"
  else
    filter_status="${GREEN}[ ]${NC}"
  fi
  printf "    ${CYAN}${ITALIC}║${NC}  ${PINK}>${NC} ${GREEN}3)${NC} %b Show dirty repos only                       ${CYAN}${ITALIC}║${NC}\n" "$filter_status"
  echo -e "    ${CYAN}${ITALIC}║${NC}                                                       ${CYAN}${ITALIC}║${NC}"
  echo -e "    ${CYAN}${ITALIC}║${NC}  ${PINK}>${NC} ${RED}0)${NC} Exit                                            ${CYAN}${ITALIC}║${NC}"
  echo -e "    ${CYAN}${ITALIC}║${NC}                                                       ${CYAN}${ITALIC}║${NC}"
  echo -e "  ${CYAN}* ${CYAN}${ITALIC}╚═══════════════════════════════════════════════════════╝${NC}${CYAN} *${NC}"
  echo ""
}

main() {
  # Non-interactive mode: --scan or -s flag just runs and exits
  if [ "${1:-}" = "--scan" ] || [ "${1:-}" = "-s" ]; then
    local scan_mode="all"
    shift
    if [ "${1:-}" = "--dirty" ] || [ "${1:-}" = "-d" ]; then
      scan_mode="dirty"; shift
    fi
    local scan_dir="${1:-.}"
    scan_dir="${scan_dir/#\~/$HOME}"
    _scan_impl "$scan_dir" "$scan_mode"
    exit 0
  fi

  # Default scan dir: first argument or current directory
  SCAN_DIR="${1:-.}"
  # Expand ~ if passed as argument
  SCAN_DIR="${SCAN_DIR/#\~/$HOME}"

  while true; do
    show_menu
    echo -ne "${BRIGHT_PINK}Select option [0-3]:${NC} "
    read -rsn1 choice || true
    echo ""
    case $choice in
      1) do_scan_default ;;
      2) do_scan_custom ;;
      3) SHOW_DIRTY_ONLY=$((1 - SHOW_DIRTY_ONLY)) ;;
      0)
        echo -e "\n${PINK}*${NC} ${GREEN}Goodbye!${NC} ${PINK}*${NC}\n"
        exit 0
        ;;
      *)
        print_error "Invalid option"
        sleep 1
        ;;
    esac
  done
}

main "$@"
