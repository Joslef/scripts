main() {
  load_config
  ensure_config

  # Silent mode for systemd service
  if [ "${1:-}" == "--run" ]; then
    do_sync
    exit $?
  fi

  while true; do
    show_menu
    read -r -p "$(echo -e "${BRIGHT_PINK}Select option [0-7, a-c]:${NC} ")" choice

    case $choice in
      1) setup_hourly ;;
      2) setup_daily ;;
      3) setup_weekly ;;
      4)
        if boot_enabled; then
          disable_boot
        else
          setup_boot
        fi
        sleep 1
        ;;
      5) do_run_now ;;
      6) show_status ;;
      7) do_disable ;;
      a|A) change_path ;;
      b|B) change_repo ;;
      c|C) do_restore ;;
      0)
        echo -e "\n${PINK}*${NC} ${GREEN}Goodbye!${NC} ${PINK}*${NC}\n"
        exit 0
        ;;
      *)
        print_error "Invalid option"
        sleep 1
        ;;
    esac
  done
}

main "$@"
