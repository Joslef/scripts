#!/bin/bash

set -uo pipefail

# ─── Colors (matching ~/scripts style) ────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
ITALIC='\033[3m'
NC='\033[0m'

PINK='\033[38;5;198m'
BRIGHT_PINK='\033[38;5;201m'
HOT_PINK='\033[38;5;205m'

# ─── Config ───────────────────────────────────────────────────────────────────
CONFIG_DIR="$HOME/.config/pkgsync"
CONFIG_FILE="$CONFIG_DIR/config"
SERVICE_NAME="pkgsync"
TIMER_NAME="pkgsync"
BOOT_SERVICE_NAME="pkgsync-boot"

REPO_DIR=""
REMOTE_URL=""

# ─── Config persistence ──────────────────────────────────────────────────────
save_config() {
  mkdir -p "$CONFIG_DIR"
  cat > "$CONFIG_FILE" <<EOF
REPO_DIR="$REPO_DIR"
REMOTE_URL="$REMOTE_URL"
EOF
}

load_config() {
  mkdir -p "$CONFIG_DIR"
  if [ -f "$CONFIG_FILE" ]; then
    source "$CONFIG_FILE"
  fi
}

# Validate config and prompt for missing/invalid values
ensure_config() {
  local needs_save=0

  # Check REPO_DIR
  if [ -z "$REPO_DIR" ] || [ ! -d "$REPO_DIR" ]; then
    if [ -n "$REPO_DIR" ] && [ ! -d "$REPO_DIR" ]; then
      echo -e "${RED}✗ Save path does not exist: ${REPO_DIR}${NC}"
    fi
    echo ""
    read -r -p "$(echo -e "${BRIGHT_PINK}Enter path for package lists (absolute path):${NC} ")" REPO_DIR
    REPO_DIR="${REPO_DIR/#\~/$HOME}"
    if [ -z "$REPO_DIR" ]; then
      echo -e "${RED}✗ No path provided. Exiting.${NC}"
      exit 1
    fi
    mkdir -p "$REPO_DIR"
    if [ ! -d "$REPO_DIR/.git" ]; then
      git -C "$REPO_DIR" init
    fi
    needs_save=1
  fi

  # Check REMOTE_URL
  if [ -z "$REMOTE_URL" ]; then
    echo ""
    read -r -p "$(echo -e "${BRIGHT_PINK}Enter GitHub repo URL (https://github.com/...):${NC} ")" REMOTE_URL
    if [ -z "$REMOTE_URL" ]; then
      echo -e "${RED}✗ No repo URL provided. Exiting.${NC}"
      exit 1
    fi
    if [[ "$REMOTE_URL" != *.git ]]; then
      REMOTE_URL="${REMOTE_URL}.git"
    fi

    # Validate GitHub access — only when a new URL is being set
    local owner_repo
    owner_repo=$(echo "$REMOTE_URL" | sed -E 's#.*github\.com[/:]##; s#\.git$##')
    if [ -z "$owner_repo" ]; then
      echo -e "${RED}✗ Cannot parse repo from URL: ${REMOTE_URL}${NC}"
      REMOTE_URL=""
      save_config
      exit 1
    fi

    if command -v gh &>/dev/null; then
      if ! gh repo view "$owner_repo" &>/dev/null; then
        echo -e "${RED}✗ Cannot access ${owner_repo}. Run 'gh auth login' first.${NC}"
        REMOTE_URL=""
        save_config
        exit 1
      fi
    fi

    needs_save=1
  fi

  if [ "$needs_save" -eq 1 ]; then
    save_config
    echo -e "${GREEN}✓ Configuration saved to ${CONFIG_FILE}${NC}"
    echo ""
  fi
}

# ─── Helper functions ─────────────────────────────────────────────────────────
print_header() {
  echo -e "\n${BLUE}=== $1 ===${NC}"
}

print_success() {
  echo -e "${GREEN}✓ $1${NC}"
}

print_warning() {
  echo -e "${YELLOW}⚠ $1${NC}"
}

print_error() {
  echo -e "${RED}✗ $1${NC}"
}

confirm() {
  read -r -p "$1 [y/N]: " response
  case "$response" in
    [yY][eE][sS]|[yY]) true ;;
    *) false ;;
  esac
}

# Pad and print a line inside the cyan box (55 visible chars between ║ ║)
box_line() {
  local text="$1"
  local color="${2:-$NC}"
  local pad=$((55 - 2 - ${#text}))
  if [ "$pad" -lt 0 ]; then pad=0; fi
  printf "    ${CYAN}${ITALIC}║${NC}  ${color}%s${NC}%*s${CYAN}${ITALIC}║${NC}\n" "$text" "$pad" ""
}

