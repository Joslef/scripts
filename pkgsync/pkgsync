# ─── Core: generate package lists, commit & push if changed ───────────────────
do_sync() {
  cd "$REPO_DIR" || { echo "ERROR: Cannot cd to $REPO_DIR"; exit 1; }

  # Ensure remote is correct
  if ! git remote get-url origin &>/dev/null; then
    git remote add origin "$REMOTE_URL"
  else
    git remote set-url origin "$REMOTE_URL"
  fi

  # Generate package lists
  pacman -Qqem > pkglist-aur.txt
  pacman -Qqen > pkglist-native.txt

  # Stage first, then check for changes (covers both new/untracked and modified files)
  git add pkglist-aur.txt pkglist-native.txt
  if git diff --cached --quiet; then
    echo "No changes detected."
    return 0
  fi

  # Commit with timestamp, push
  local timestamp
  timestamp=$(date +"%Y-%m-%d_%H-%M")
  git commit -m "$timestamp"
  git push origin main || { echo "ERROR: git push failed"; exit 1; }
  echo "Pushed changes: $timestamp"
}

# ─── Systemd unit paths ──────────────────────────────────────────────────────
UNIT_DIR="$HOME/.config/systemd/user"

ensure_unit_dir() {
  mkdir -p "$UNIT_DIR"
}

# ─── Write the service unit (shared by timer and boot) ────────────────────────
write_service() {
  local name="$1"
  ensure_unit_dir
  cat > "$UNIT_DIR/${name}.service" <<EOF
[Unit]
Description=PkgSync - Sync package lists to GitHub

[Service]
Type=oneshot
ExecStart=$(command -v pkgsync) --run
EOF
  print_success "Created ${name}.service"
}

# ─── Write timer unit ────────────────────────────────────────────────────────
write_timer() {
  local on_calendar="$1"
  ensure_unit_dir
  cat > "$UNIT_DIR/${TIMER_NAME}.timer" <<EOF
[Unit]
Description=PkgSync - Package list sync timer

[Timer]
OnCalendar=${on_calendar}
Persistent=true

[Install]
WantedBy=timers.target
EOF
  print_success "Created ${TIMER_NAME}.timer (${on_calendar})"
}

# ─── Write boot service ──────────────────────────────────────────────────────
write_boot_service() {
  ensure_unit_dir
  cat > "$UNIT_DIR/${BOOT_SERVICE_NAME}.service" <<EOF
[Unit]
Description=PkgSync - Sync package lists on boot
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
ExecStartPre=/bin/sleep 30
ExecStart=$(command -v pkgsync) --run

[Install]
WantedBy=default.target
EOF
  print_success "Created ${BOOT_SERVICE_NAME}.service"
}

# ─── Enable / disable helpers ─────────────────────────────────────────────────
enable_timer() {
  systemctl --user daemon-reload
  systemctl --user enable --now "${TIMER_NAME}.timer"
  print_success "Timer enabled and started"
}

disable_timer() {
  systemctl --user disable --now "${TIMER_NAME}.timer" 2>/dev/null
  rm -f "$UNIT_DIR/${TIMER_NAME}.timer" "$UNIT_DIR/${SERVICE_NAME}.service"
  systemctl --user daemon-reload
  print_success "Timer disabled and removed"
}

enable_boot() {
  systemctl --user daemon-reload
  systemctl --user enable "${BOOT_SERVICE_NAME}.service"
  print_success "Boot sync enabled"
}

disable_boot() {
  systemctl --user disable "${BOOT_SERVICE_NAME}.service" 2>/dev/null
  rm -f "$UNIT_DIR/${BOOT_SERVICE_NAME}.service"
  systemctl --user daemon-reload
  print_success "Boot sync disabled and removed"
}

# ─── Status helpers ───────────────────────────────────────────────────────────
timer_active() {
  systemctl --user is-active "${TIMER_NAME}.timer" &>/dev/null
}

boot_enabled() {
  systemctl --user is-enabled "${BOOT_SERVICE_NAME}.service" &>/dev/null
}

get_timer_schedule() {
  if [ -f "$UNIT_DIR/${TIMER_NAME}.timer" ]; then
    grep "OnCalendar=" "$UNIT_DIR/${TIMER_NAME}.timer" 2>/dev/null | cut -d= -f2
  fi
}

get_timer_next() {
  systemctl --user list-timers "${TIMER_NAME}.timer" --no-pager 2>/dev/null | grep "$TIMER_NAME" | awk '{print $1, $2, $3}'
}

# Translate OnCalendar value to human-readable text with timezone
human_schedule() {
  local cal="$1"
  local tz
  tz=$(timedatectl show -p Timezone --value 2>/dev/null || date +%Z)

  case "$cal" in
    hourly)
      echo "Every hour"
      ;;
    *-*-*\ *:*:*)
      # Daily or weekly with time
      local time_part day_part
      if [[ "$cal" =~ ^([A-Za-z]+)\ .+\ ([0-9]{2}:[0-9]{2}) ]]; then
        # Weekly: "Mon *-*-* 18:00:00"
        day_part="${BASH_REMATCH[1]}"
        time_part="${BASH_REMATCH[2]}"
        local full_day
        case "$day_part" in
          Mon) full_day="Monday" ;; Tue) full_day="Tuesday" ;; Wed) full_day="Wednesday" ;;
          Thu) full_day="Thursday" ;; Fri) full_day="Friday" ;; Sat) full_day="Saturday" ;;
          Sun) full_day="Sunday" ;; *) full_day="$day_part" ;;
        esac
        echo "Every ${full_day} at ${time_part} ${tz}"
      elif [[ "$cal" =~ ([0-9]{2}:[0-9]{2}) ]]; then
        # Daily: "*-*-* 18:00:00"
        time_part="${BASH_REMATCH[1]}"
        echo "Every day at ${time_part} ${tz}"
      else
        echo "$cal"
      fi
      ;;
    *)
      echo "$cal"
      ;;
  esac
}

# Extract short repo name from URL (e.g. "Joslef/CachyOS_pkglist")
short_repo() {
  echo "$REMOTE_URL" | sed -E 's#.*github\.com[/:]##; s#\.git$##'
}

# ─── Schedule setup functions ─────────────────────────────────────────────────
setup_hourly() {
  write_service "$SERVICE_NAME"
  write_timer "hourly"
  enable_timer
}

setup_daily() {
  echo ""
  read -r -p "$(echo -e "${BRIGHT_PINK}Time to run (HH:MM, 24h format) [default 04:00]:${NC} ")" time_input
  time_input="${time_input:-04:00}"

  # Validate format
  if ! [[ "$time_input" =~ ^([01][0-9]|2[0-3]):[0-5][0-9]$ ]]; then
    print_error "Invalid time format. Use HH:MM (e.g. 14:30)"
    sleep 2
    return
  fi

  local tz
  tz=$(timedatectl show -p Timezone --value 2>/dev/null || date +%Z)

  write_service "$SERVICE_NAME"
  write_timer "*-*-* ${time_input}:00"
  enable_timer
  echo ""
  print_success "Scheduled: Every day at ${time_input} ${tz}"
  sleep 2
}

setup_weekly() {
  echo ""
  echo -e "  ${GREEN}1)${NC} Monday"
  echo -e "  ${GREEN}2)${NC} Tuesday"
  echo -e "  ${GREEN}3)${NC} Wednesday"
  echo -e "  ${GREEN}4)${NC} Thursday"
  echo -e "  ${GREEN}5)${NC} Friday"
  echo -e "  ${GREEN}6)${NC} Saturday"
  echo -e "  ${GREEN}7)${NC} Sunday"
  echo ""
  read -r -p "$(echo -e "${BRIGHT_PINK}Select weekday [1-7]:${NC} ")" day_choice

  local day_name
  case "$day_choice" in
    1) day_name="Mon" ;; 2) day_name="Tue" ;; 3) day_name="Wed" ;;
    4) day_name="Thu" ;; 5) day_name="Fri" ;; 6) day_name="Sat" ;;
    7) day_name="Sun" ;;
    *)
      print_error "Invalid choice"
      sleep 2
      return
      ;;
  esac

  read -r -p "$(echo -e "${BRIGHT_PINK}Time to run (HH:MM, 24h format) [default 04:00]:${NC} ")" time_input
  time_input="${time_input:-04:00}"

  if ! [[ "$time_input" =~ ^([01][0-9]|2[0-3]):[0-5][0-9]$ ]]; then
    print_error "Invalid time format. Use HH:MM (e.g. 14:30)"
    sleep 2
    return
  fi

  local full_day tz
  case "$day_name" in
    Mon) full_day="Monday" ;; Tue) full_day="Tuesday" ;; Wed) full_day="Wednesday" ;;
    Thu) full_day="Thursday" ;; Fri) full_day="Friday" ;; Sat) full_day="Saturday" ;;
    Sun) full_day="Sunday" ;;
  esac
  tz=$(timedatectl show -p Timezone --value 2>/dev/null || date +%Z)

  write_service "$SERVICE_NAME"
  write_timer "${day_name} *-*-* ${time_input}:00"
  enable_timer
  echo ""
  print_success "Scheduled: Every ${full_day} at ${time_input} ${tz}"
  sleep 2
}

setup_boot() {
  write_boot_service
  enable_boot
}

# ─── Change save path ────────────────────────────────────────────────────────
change_path() {
  print_header "Change Save Path"
  echo -e "  Current: ${BOLD}${REPO_DIR}${NC}"
  echo ""
  read -r -p "$(echo -e "${BRIGHT_PINK}New path (absolute):${NC} ")" new_path

  # Expand ~
  new_path="${new_path/#\~/$HOME}"

  if [ -z "$new_path" ]; then
    print_warning "No path entered, keeping current."
    sleep 1
    return
  fi

  # Same path check
  if [ "$(realpath -m "$new_path")" == "$(realpath -m "$REPO_DIR")" ]; then
    print_warning "Same as current path, nothing to do."
    sleep 1
    return
  fi

  local old_dir="$REPO_DIR"

  # Create new directory
  mkdir -p "$new_path"

  # Move files (and .git) from old to new
  if [ -d "$old_dir/.git" ]; then
    # Move everything from old repo to new location
    cp -a "$old_dir/." "$new_path/"
    print_success "Moved repo to ${new_path}"

    # Ask about deleting old directory
    echo ""
    if confirm "Delete old directory ${old_dir}?"; then
      rm -rf "$old_dir"
      print_success "Deleted ${old_dir}"
    else
      print_warning "Old directory kept at ${old_dir}"
    fi
  else
    # No existing repo — init fresh
    cd "$new_path" || return
    git init
    git remote add origin "$REMOTE_URL"
    print_success "Initialized new repo at ${new_path}"
  fi

  REPO_DIR="$new_path"
  save_config
  print_success "Save path updated to: ${REPO_DIR}"
  echo ""
  read -r -p "Press Enter to continue..."
}

# ─── Change GitHub repo ──────────────────────────────────────────────────────
change_repo() {
  print_header "Change GitHub Repository"
  echo -e "  Current: ${BOLD}$(short_repo)${NC}"
  echo ""
  read -r -p "$(echo -e "${BRIGHT_PINK}GitHub repo URL (https://github.com/...):${NC} ")" new_url

  if [ -z "$new_url" ]; then
    print_warning "No URL entered, keeping current."
    sleep 1
    return
  fi

  # Normalize: ensure .git suffix
  if [[ "$new_url" != *.git ]]; then
    new_url="${new_url}.git"
  fi

  # Extract owner/repo for gh auth check
  local owner_repo
  owner_repo=$(echo "$new_url" | sed -E 's#.*github\.com[/:]##; s#\.git$##')

  if [ -z "$owner_repo" ]; then
    print_error "Could not parse repository from URL."
    sleep 2
    return
  fi

  # Check gh authentication
  if ! command -v gh &>/dev/null; then
    print_error "gh CLI is not installed. Install it with: sudo pacman -S github-cli"
    sleep 2
    return
  fi

  echo -e "  Checking access to ${BOLD}${owner_repo}${NC}..."
  if ! gh repo view "$owner_repo" &>/dev/null; then
    print_error "Cannot access ${owner_repo}. Are you authenticated?"
    echo -e "  Run ${BOLD}gh auth login${NC} to authenticate."
    sleep 3
    return
  fi

  REMOTE_URL="$new_url"
  save_config

  # Update remote in existing repo
  if [ -d "$REPO_DIR/.git" ]; then
    cd "$REPO_DIR" || return
    git remote set-url origin "$REMOTE_URL" 2>/dev/null || git remote add origin "$REMOTE_URL"
  fi

  print_success "Repository set to: ${owner_repo}"
  echo ""
  read -r -p "Press Enter to continue..."
}

# ─── Detect AUR helper ────────────────────────────────────────────────────────
detect_aur_helper() {
  if command -v paru &>/dev/null; then
    echo "paru"
  elif command -v yay &>/dev/null; then
    echo "yay"
  else
    echo ""
  fi
}

# ─── Restore from repo ────────────────────────────────────────────────────────
do_restore() {
  cd "$REPO_DIR" || { print_error "Cannot cd to $REPO_DIR"; return 1; }

  # Ensure remote is correct and pull latest
  if ! git remote get-url origin &>/dev/null; then
    git remote add origin "$REMOTE_URL"
  else
    git remote set-url origin "$REMOTE_URL"
  fi

  echo -e "  Pulling latest from repo..."
  if ! git fetch origin main; then
    print_error "Failed to fetch from remote"
    echo ""
    read -r -p "Press Enter to continue..."
    return 1
  fi
  git checkout main 2>/dev/null || git checkout -b main origin/main
  git reset --hard origin/main

  local missing_native="" missing_aur=""
  local count_native=0 count_aur=0

  # Compare native packages
  if [ -f pkglist-native.txt ]; then
    missing_native=$(comm -23 <(sort pkglist-native.txt) <(pacman -Qqen | sort))
    if [ -n "$missing_native" ]; then
      count_native=$(echo "$missing_native" | wc -l | tr -d ' ')
    fi
  fi

  # Compare AUR packages
  if [ -f pkglist-aur.txt ]; then
    missing_aur=$(comm -23 <(sort pkglist-aur.txt) <(pacman -Qqem | sort))
    if [ -n "$missing_aur" ]; then
      count_aur=$(echo "$missing_aur" | wc -l | tr -d ' ')
    fi
  fi

  local total=$((count_native + count_aur))

  if [ "$total" -eq 0 ]; then
    echo ""
    print_success "All packages from repo are installed locally"
    echo ""
    read -r -p "Press Enter to continue..."
    return 0
  fi

  echo ""
  echo -e "  ${BOLD}Missing packages:${NC}"
  echo ""

  if [ -n "$missing_native" ]; then
    echo -e "  ${GREEN}Native (${count_native}):${NC}"
    echo "$missing_native" | while read -r pkg; do
      echo -e "    ${pkg}"
    done
    echo ""
  fi

  if [ -n "$missing_aur" ]; then
    echo -e "  ${GREEN}AUR (${count_aur}):${NC}"
    echo "$missing_aur" | while read -r pkg; do
      echo -e "    ${pkg}"
    done
    echo ""
  fi

  echo -e "  ${BOLD}Total: ${total} package(s) to install${NC}"
  echo ""

  if [ -n "$missing_native" ]; then
    echo -e "  Installing native packages..."
    local -a native_pkgs
    mapfile -t native_pkgs < <(echo "$missing_native" | tr -d '\r')
    if ! sudo pacman -S --needed "${native_pkgs[@]}"; then
      print_error "Some native packages failed to install"
    fi
  fi

  if [ -n "$missing_aur" ]; then
    local aur_helper
    aur_helper=$(detect_aur_helper)
    if [ -z "$aur_helper" ]; then
      print_error "No AUR helper found (install yay or paru first)"
      echo -e "  Skipping AUR packages"
    else
      echo -e "  Installing AUR packages via ${BOLD}${aur_helper}${NC}..."
      local -a aur_pkgs
      mapfile -t aur_pkgs < <(echo "$missing_aur" | tr -d '\r')
      if ! "$aur_helper" -S --needed "${aur_pkgs[@]}"; then
        print_error "Some AUR packages failed to install"
      fi
    fi
  fi

  echo ""
  print_success "Restore complete"
  echo ""
  read -r -p "Press Enter to continue..."
}

# ─── Run now ──────────────────────────────────────────────────────────────────
do_run_now() {
  print_header "Running sync now"
  do_sync
  echo ""
  read -r -p "Press Enter to continue..."
}

# ─── Show current status ─────────────────────────────────────────────────────
show_status() {
  print_header "Current Status"

  # Timer status
  if timer_active; then
    local schedule_raw schedule_human next
    schedule_raw=$(get_timer_schedule)
    schedule_human=$(human_schedule "$schedule_raw")
    next=$(get_timer_next)
    print_success "Timer is active"
    echo -e "  Schedule : ${BOLD}${schedule_human}${NC}"
    if [ -n "$next" ]; then
      echo -e "  Next run : ${BOLD}${next}${NC}"
    fi
  else
    print_warning "Timer is not active"
  fi

  # Boot status
  if boot_enabled; then
    print_success "Boot sync is enabled"
  else
    print_warning "Boot sync is not enabled"
  fi

  echo -e "  Path     : ${BOLD}${REPO_DIR}${NC}"
  echo -e "  Repo     : ${BOLD}$(short_repo)${NC}"

  echo ""
  read -r -p "Press Enter to continue..."
}

# ─── Disable menu ────────────────────────────────────────────────────────────
do_disable() {
  echo ""
  echo -e "  ${GREEN}1)${NC} Disable timer (hourly/daily/weekly)"
  echo -e "  ${GREEN}2)${NC} Disable boot sync"
  echo -e "  ${GREEN}3)${NC} Disable all"
  echo -e "  ${GREEN}0)${NC} Back"
  echo ""
  read -r -p "$(echo -e "${BRIGHT_PINK}Select [0-3]:${NC} ")" choice

  case "$choice" in
    1) disable_timer ;;
    2) disable_boot ;;
    3) disable_timer; disable_boot ;;
    0) return ;;
    *) print_error "Invalid option"; sleep 1 ;;
  esac
  echo ""
  read -r -p "Press Enter to continue..."
}

