# ─── Cleanup on exit ─────────────────────────────────────────────────────────
MPV_PID=""
VISUALIZER_PID=""

cleanup() {
  # Kill visualizer if running
  if [ -n "$VISUALIZER_PID" ] && kill -0 "$VISUALIZER_PID" 2>/dev/null; then
    kill "$VISUALIZER_PID" 2>/dev/null
    wait "$VISUALIZER_PID" 2>/dev/null
  fi
  # Kill mpv if running
  if [ -n "$MPV_PID" ] && kill -0 "$MPV_PID" 2>/dev/null; then
    kill "$MPV_PID" 2>/dev/null
    wait "$MPV_PID" 2>/dev/null
  fi
  # Restore cursor and clear line
  printf "\033[?25h\033[2K"
  rm -f /tmp/audioshell_mpv_ipc_$$ 2>/dev/null
}

trap cleanup EXIT
trap 'cleanup; exit 130' INT

