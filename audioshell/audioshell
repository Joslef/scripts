#!/bin/bash

set -uo pipefail

# ─── Colors ───────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
BOLD='\033[1m'
ITALIC='\033[3m'
NC='\033[0m'

PINK='\033[38;5;198m'
BRIGHT_PINK='\033[38;5;201m'
HOT_PINK='\033[38;5;205m'

ORANGE='\033[38;5;208m'
PURPLE='\033[38;5;141m'
SKY_BLUE='\033[38;5;117m'
GOLD='\033[38;5;220m'
LIME='\033[38;5;118m'

# ─── Animation arrays (global, initialized after colors) ──────────────────────
declare -a ANIM_MUSIC_L=('♪' '♫' '♬' '♩' '♪' '♫' '♬' '♩')
declare -a ANIM_MUSIC_R=('♫' '♬' '♩' '♪' '♫' '♬' '♩' '♪')
declare -a ANIM_BARS=('▁' '▂' '▃' '▄' '▅' '▆' '▇' '█' '▇' '▆' '▅' '▄' '▃' '▂')
declare -a ANIM_COLORS

# ─── Radio Stations ───────────────────────────────────────────────────────────
declare -a STATION_NAMES=(
  "amambient"
  "ambientradio"
  "anotherplanet"
  "cliqhop"
  "costadelmar"
  "deepspaceone"
  "defcon"
  "dronezone"
  "dubstep"
  "egochillout"
  "egoflash"
  "egofm"
  "egorap"
  "egosun"
  "groovesalad"
  "groovesaladclassic"
  "missioncontrol"
  "psyradio"
  "schizoid"
  "secretagent"
  "seventies"
  "sleepingpill"
  "spacestation"
  "synphaer"
  "zerobeat"
)

get_station_url() {
  case "$1" in
    dronezone)          echo "http://api.somafm.com/dronezone.pls" ;;
    groovesalad)        echo "http://api.somafm.com/groovesalad.pls" ;;
    deepspaceone)       echo "http://api.somafm.com/deepspaceone.pls" ;;
    spacestation)       echo "http://api.somafm.com/spacestation.pls" ;;
    anotherplanet)      echo "http://stream.anotherplanet.fm:8000/stream.mp3" ;;
    psyradio)           echo "http://host.psyradio.fm:8020/;listen.mp3" ;;
    egochillout)        echo "https://streams.egofm.de/egoCHILLOUT-hq" ;;
    egosun)             echo "https://streams.egofm.de/egoSUN-hq" ;;
    egoflash)           echo "https://streams.egofm.de/egoFLASH-hq" ;;
    egofm)              echo "https://streams.egofm.de/egoFM-hq" ;;
    sleepingpill)       echo "http://s.stereoscenic.com/asp-h.pls" ;;
    schizoid)           echo "http://schizoid.in/schizoid-chill.pls" ;;
    costadelmar)        echo "https://radio4.cdm-radio.com:18020/stream-mp3-Chill" ;;
    amambient)          echo "http://radio.stereoscenic.com/ama-h" ;;
    zerobeat)           echo "http://zerobeatzone.mrg.fm:8800/stream3" ;;
    ambientradio)       echo "http://listen.mrg.fm:8888/stream" ;;
    egorap)             echo "https://streams.egofm.de/egoRAP-hq" ;;
    cliqhop)            echo "http://api.somafm.com/cliqhop.pls" ;;
    defcon)             echo "http://api.somafm.com/defcon.pls" ;;
    dubstep)            echo "http://api.somafm.com/dubstep.pls" ;;
    groovesaladclassic) echo "http://api.somafm.com/gsclassic.pls" ;;
    missioncontrol)     echo "http://api.somafm.com/missioncontrol.pls" ;;
    secretagent)        echo "http://api.somafm.com/secretagent.pls" ;;
    seventies)          echo "http://api.somafm.com/seventies.pls" ;;
    synphaer)           echo "http://api.somafm.com/synphaera.pls" ;;
