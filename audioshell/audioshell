# ─── Now-Playing Visualizer ───────────────────────────────────────────────────
# Animated playback display with dancing music symbols and colored metadata
run_visualizer() {
  local station_name="$1"
  local ipc_socket="$2"

  # Music symbol sets for dancing animation
  local -a music_left=('♪' '♫' '♬' '♩' '♪' '♫' '♬' '♩')
  local -a music_right=('♫' '♬' '♩' '♪' '♫' '♬' '♩' '♪')
  local -a bounce=('⠁' '⠂' '⠄' '⡀' '⠄' '⠂' '⠁' '⠈' '⠐' '⠠' '⠐' '⠈')
  local -a bars=('▁' '▂' '▃' '▄' '▅' '▆' '▇' '█' '▇' '▆' '▅' '▄' '▃' '▂')
  local -a color_cycle=("$BRIGHT_PINK" "$HOT_PINK" "$PURPLE" "$SKY_BLUE" "$CYAN" "$LIME" "$GOLD" "$ORANGE")

  local frame=0
  local prev_title=""
  local title=""
  local artist=""
  local display_title=""

  printf "\033[?25l"  # hide cursor

  while true; do
    # Query mpv for metadata via IPC socket
    if [ -S "$ipc_socket" ]; then
      local raw_title raw_artist
      raw_title=$(echo '{"command":["get_property","media-title"]}' | socat - "$ipc_socket" 2>/dev/null | sed -n 's/.*"data":"\([^"]*\)".*/\1/p')
      raw_artist=$(echo '{"command":["get_property","metadata/by-key/artist"]}' | socat - "$ipc_socket" 2>/dev/null | sed -n 's/.*"data":"\([^"]*\)".*/\1/p')

      if [ -n "$raw_title" ]; then
        # Some streams put "Artist - Title" in the title field
        if [ -z "$raw_artist" ] && [[ "$raw_title" == *" - "* ]]; then
          artist="${raw_title%% - *}"
          title="${raw_title#* - }"
        elif [ -n "$raw_artist" ]; then
          artist="$raw_artist"
          title="$raw_title"
        else
          artist=""
          title="$raw_title"
        fi
      fi
    fi

    # Build the animated display
    local ci=$((frame % ${#color_cycle[@]}))
    local mi_l=$((frame % ${#music_left[@]}))
    local mi_r=$(( (frame + 4) % ${#music_right[@]} ))
    local bi=$((frame % ${#bars[@]}))
    local bi2=$(( (frame + 3) % ${#bars[@]}))
    local bi3=$(( (frame + 7) % ${#bars[@]}))
    local bi4=$(( (frame + 5) % ${#bars[@]}))
    local bi5=$(( (frame + 10) % ${#bars[@]}))

    local c1="${color_cycle[$ci]}"
    local c2="${color_cycle[$(( (ci + 2) % ${#color_cycle[@]} ))]}"
    local c3="${color_cycle[$(( (ci + 4) % ${#color_cycle[@]} ))]}"
    local c4="${color_cycle[$(( (ci + 6) % ${#color_cycle[@]} ))]}"

    # Equalizer bars animation
    local eq="${c1}${bars[$bi]}${c2}${bars[$bi2]}${c3}${bars[$bi3]}${c4}${bars[$bi4]}${c1}${bars[$bi5]}${NC}"

    # Dancing music notes
    local note_l="${c2}${music_left[$mi_l]}${NC}"
    local note_r="${c3}${music_right[$mi_r]}${NC}"

    # Build now-playing line
    local now_playing=""
    if [ -n "$artist" ] && [ -n "$title" ]; then
      now_playing="${GOLD}${BOLD}${artist}${NC} ${CYAN}-${NC} ${PURPLE}${ITALIC}${title}${NC}"
    elif [ -n "$title" ]; then
      now_playing="${PURPLE}${ITALIC}${title}${NC}"
    else
      now_playing="${YELLOW}Connecting...${NC}"
    fi

    # Move cursor up and redraw (3 lines: separator, station, now-playing)
    if [ "$frame" -gt 0 ]; then
      printf "\033[3A"
    fi

    printf "\033[2K  ${note_l} ${eq} ${note_r}  ${c1}${music_left[$(( (frame+2) % ${#music_left[@]} ))]}${NC} ${eq} ${c4}${music_right[$(( (frame+1) % ${#music_right[@]} ))]}${NC}  ${note_l} ${eq} ${note_r}\n"
    printf "\033[2K  ${c1}▶${NC}  ${GREEN}${BOLD}${station_name}${NC}\n"
    printf "\033[2K     ${now_playing}\n"

    frame=$((frame + 1))
    sleep 0.3
  done
}

# ─── Play station ─────────────────────────────────────────────────────────────
play_station() {
  local station_name="$1"
  local station_url="${STATION_URLS[$station_name]}"
  local ipc_socket="/tmp/audioshell_mpv_ipc_$$"

  clear
  echo ""
  echo -e "  ${CYAN}* ${CYAN}${ITALIC}╔═══════════════════════════════════════════════════════╗${NC}${CYAN} *"
  echo -e "    ${CYAN}${ITALIC}║${NC} ${BRIGHT_PINK}* Now Playing *${NC}                                       ${CYAN}${ITALIC}║${NC}"
  echo -e "    ${CYAN}${ITALIC}╠═══════════════════════════════════════════════════════╣${NC}"
  echo -e "    ${CYAN}${ITALIC}║${NC}                                                       ${CYAN}${ITALIC}║${NC}"
  echo -e "    ${CYAN}${ITALIC}║${NC}  ${GREEN}Station:${NC} ${BOLD}${station_name}${NC}$(printf '%*s' $((44 - ${#station_name})) '')${CYAN}${ITALIC}║${NC}"
  echo -e "    ${CYAN}${ITALIC}║${NC}                                                       ${CYAN}${ITALIC}║${NC}"
  echo -e "    ${CYAN}${ITALIC}║${NC}  ${YELLOW}Press ${BOLD}q${NC}${YELLOW} to stop and return to menu${NC}                   ${CYAN}${ITALIC}║${NC}"
  echo -e "    ${CYAN}${ITALIC}║${NC}  ${YELLOW}Press ${BOLD}9${NC}${YELLOW}/${BOLD}0${NC}${YELLOW} to adjust volume${NC}                           ${CYAN}${ITALIC}║${NC}"
  echo -e "    ${CYAN}${ITALIC}║${NC}  ${YELLOW}Press ${BOLD}m${NC}${YELLOW} to mute/unmute${NC}                               ${CYAN}${ITALIC}║${NC}"
  echo -e "    ${CYAN}${ITALIC}║${NC}                                                       ${CYAN}${ITALIC}║${NC}"
  echo -e "  ${CYAN}* ${CYAN}${ITALIC}╚═══════════════════════════════════════════════════════╝${NC}${CYAN} *${NC}"
  echo ""

  # Start mpv in background with IPC socket for metadata queries
  mpv --no-video --really-quiet \
    --input-ipc-server="$ipc_socket" \
    --term-osd-bar \
    "$station_url" &
  MPV_PID=$!

  # Give mpv a moment to create the socket
  sleep 1

  # Start the visualizer in background
  run_visualizer "$station_name" "$ipc_socket" &
  VISUALIZER_PID=$!

  # Wait for mpv to finish (user presses q in terminal or mpv dies)
  wait "$MPV_PID" 2>/dev/null
  MPV_PID=""

  # Kill visualizer
  if [ -n "$VISUALIZER_PID" ] && kill -0 "$VISUALIZER_PID" 2>/dev/null; then
    kill "$VISUALIZER_PID" 2>/dev/null
    wait "$VISUALIZER_PID" 2>/dev/null
  fi
  VISUALIZER_PID=""

  printf "\033[?25h"  # restore cursor
  rm -f "$ipc_socket" 2>/dev/null
}

# ─── Station list menu ────────────────────────────────────────────────────────
show_menu() {
  clear
  print_banner

  echo -e "  ${CYAN}* ${CYAN}${ITALIC}╔═══════════════════════════════════════════════════════╗${NC}${CYAN} *"
  echo -e "    ${CYAN}${ITALIC}║${NC} ${BRIGHT_PINK}* Internet Radio Stations *${NC}                           ${CYAN}${ITALIC}║${NC}"
  echo -e "    ${CYAN}${ITALIC}╠═══════════════════════════════════════════════════════╣${NC}"
  echo -e "    ${CYAN}${ITALIC}║${NC}                                                       ${CYAN}${ITALIC}║${NC}"

  local i=1
  for name in "${STATION_NAMES[@]}"; do
    local num
    num=$(printf "%2d" "$i")
    local pad=$((47 - ${#name}))
    if [ "$pad" -lt 0 ]; then pad=0; fi
    printf "    ${CYAN}${ITALIC}║${NC}  ${PINK}>${NC} ${GREEN}%s)${NC} ${BOLD}%s${NC}%*s${CYAN}${ITALIC}║${NC}\n" "$num" "$name" "$pad" ""
    i=$((i + 1))
  done

  echo -e "    ${CYAN}${ITALIC}║${NC}                                                       ${CYAN}${ITALIC}║${NC}"
  echo -e "    ${CYAN}${ITALIC}║${NC}  ${PINK}>${NC} ${RED} 0)${NC} Exit                                           ${CYAN}${ITALIC}║${NC}"
  echo -e "    ${CYAN}${ITALIC}║${NC}                                                       ${CYAN}${ITALIC}║${NC}"
  echo -e "  ${CYAN}* ${CYAN}${ITALIC}╚═══════════════════════════════════════════════════════╝${NC}${CYAN} *${NC}"
  echo ""
}

# ─── Main ─────────────────────────────────────────────────────────────────────
main() {
  # Check dependencies
  if ! command -v mpv &>/dev/null; then
    print_error "mpv is not installed. Install it with: sudo pacman -S mpv"
    exit 1
  fi

  if ! command -v socat &>/dev/null; then
    print_warning "socat not found. Metadata display will be limited."
    print_warning "Install with: sudo pacman -S socat"
    echo ""
  fi

  local total=${#STATION_NAMES[@]}

  while true; do
    show_menu
    read -r -p "$(echo -e "${BRIGHT_PINK}Select station [0-${total}]:${NC} ")" choice

    if [ "$choice" == "0" ]; then
      echo -e "\n${PINK}*${NC} ${GREEN}Goodbye!${NC} ${PINK}*${NC}\n"
      exit 0
    fi

    # Validate numeric input
    if ! [[ "$choice" =~ ^[0-9]+$ ]] || [ "$choice" -lt 1 ] || [ "$choice" -gt "$total" ]; then
      print_error "Invalid option"
      sleep 1
      continue
    fi

    local idx=$((choice - 1))
    local selected="${STATION_NAMES[$idx]}"
    play_station "$selected"
  done
}

main "$@"
