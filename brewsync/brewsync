  echo -e "    ${CYAN}${ITALIC}в•‘${NC}  ${PINK}>${NC} ${GREEN}5)${NC} Run sync now                                    ${CYAN}${ITALIC}в•‘${NC}"
  echo -e "    ${CYAN}${ITALIC}в•‘${NC}  ${PINK}>${NC} ${GREEN}6)${NC} Show status                                     ${CYAN}${ITALIC}в•‘${NC}"
  echo -e "    ${CYAN}${ITALIC}в•‘${NC}  ${PINK}>${NC} ${GREEN}7)${NC} Disable / Remove                                ${CYAN}${ITALIC}в•‘${NC}"
  echo -e "    ${CYAN}${ITALIC}в•‘${NC}                                                       ${CYAN}${ITALIC}в•‘${NC}"
  echo -e "    ${CYAN}${ITALIC}в•‘${NC}  ${PINK}>${NC} ${RED}0)${NC} Exit                                            ${CYAN}${ITALIC}в•‘${NC}"
  echo -e "    ${CYAN}${ITALIC}в•‘${NC}                                                       ${CYAN}${ITALIC}в•‘${NC}"
  echo -e "  ${CYAN}* ${CYAN}${ITALIC}в•ҡв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•қ${NC}${CYAN} *${NC}"
  echo ""
}

main() {
  load_config
  ensure_config

  # Silent mode for launchd
  if [ "${1:-}" == "--run" ]; then
    do_sync
    exit $?
  fi

  while true; do
    show_menu
    read -r -p "$(echo -e "${BRIGHT_PINK}Select option [0-7, a-c]:${NC} ")" choice
    clear_up 1

    case $choice in
      1|2|3|5|6)
        if [ -z "$REPO_DIR" ] || [ -z "$REMOTE_URL" ]; then
          ensure_config
        else
          case $choice in
            1) setup_hourly ;;
            2) setup_daily ;;
            3) setup_weekly ;;
            5) do_run_now ;;
            6) show_status ;;
          esac
        fi
        ;;
      7) do_disable ;;
      a|A)
        if [ -z "$REPO_DIR" ] || [ -z "$REMOTE_URL" ]; then
          ensure_config
        else
          change_path
        fi
        ;;
      b|B) change_repo ;;
      c|C)
        if [ -z "$REPO_DIR" ] || [ -z "$REMOTE_URL" ]; then
          ensure_config
        else
          do_restore
        fi
        ;;
      0)
        echo -e "\n${PINK}*${NC} ${GREEN}Goodbye!${NC} ${PINK}*${NC}\n"
        exit 0
        ;;
      *)
        print_error "Invalid option"
        sleep 1
        ;;
    esac
  done
}

main "$@"
