# в”Җв”Җв”Җ Core: generate package lists, commit & push if changed в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
do_sync() (
  cd "$REPO_DIR" || { echo "ERROR: Cannot cd to $REPO_DIR"; exit 1; }

  # Ensure remote is correct
  if ! git remote get-url origin &>/dev/null; then
    git remote add origin "$REMOTE_URL"
  else
    git remote set-url origin "$REMOTE_URL"
  fi

  # Generate package lists
  if ! command -v brew &>/dev/null; then
    echo "ERROR: brew not found"
    exit 1
  fi

  brew list --formula -1 | sort > brewlist-formula.txt
  brew list --cask -1 | sort > brewlist-cask.txt

  # Mac App Store apps (optional вҖ” only if mas is installed)
  if command -v mas &>/dev/null; then
    mas list | sort > maslist.txt
  else
    # Create empty file if mas is not installed to keep git clean
    if [ ! -f maslist.txt ]; then
      touch maslist.txt
    fi
  fi

  # Stage and check for changes
  git add brewlist-formula.txt brewlist-cask.txt maslist.txt
  if git diff --cached --quiet; then
    echo "No changes detected."
    exit 0
  fi

  # Commit with timestamp, push
  local timestamp
  timestamp=$(date +"%Y-%m-%d_%H-%M")
  git commit -m "$timestamp"
  git push -u origin main || { echo "ERROR: git push failed"; exit 1; }
  echo "Pushed changes: $timestamp"
)

# в”Җв”Җв”Җ launchd helpers в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
write_plist() {
  local interval="$1"
  mkdir -p "$LAUNCHD_DIR"

  cat > "$PLIST_FILE" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>${PLIST_LABEL}</string>
    <key>ProgramArguments</key>
    <array>
        <string>${SCRIPT_PATH}</string>
        <string>--run</string>
    </array>
    <key>StartInterval</key>
    <integer>${interval}</integer>
    <key>StandardOutPath</key>
    <string>${CONFIG_DIR}/brewsync.log</string>
    <key>StandardErrorPath</key>
    <string>${CONFIG_DIR}/brewsync.err</string>
    <key>WorkingDirectory</key>
    <string>${HOME}</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>
</dict>
</plist>
EOF
}

write_plist_calendar() {
  local hour="$1"
  local minute="$2"
  local weekday="${3:-}"  # empty = daily
  mkdir -p "$LAUNCHD_DIR"

  cat > "$PLIST_FILE" <<PLISTEOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>${PLIST_LABEL}</string>
    <key>ProgramArguments</key>
    <array>
        <string>${SCRIPT_PATH}</string>
        <string>--run</string>
    </array>
    <key>StartCalendarInterval</key>
    <dict>
PLISTEOF

  if [ -n "$weekday" ]; then
    cat >> "$PLIST_FILE" <<PLISTEOF
        <key>Weekday</key>
        <integer>${weekday}</integer>
PLISTEOF
  fi

  cat >> "$PLIST_FILE" <<PLISTEOF
        <key>Hour</key>
        <integer>${hour}</integer>
        <key>Minute</key>
        <integer>${minute}</integer>
    </dict>
    <key>StandardOutPath</key>
    <string>${CONFIG_DIR}/brewsync.log</string>
    <key>StandardErrorPath</key>
    <string>${CONFIG_DIR}/brewsync.err</string>
    <key>WorkingDirectory</key>
    <string>${HOME}</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>
</dict>
</plist>
PLISTEOF
}

