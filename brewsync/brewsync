#!/bin/bash

set -euo pipefail

# в”Җв”Җв”Җ Colors (matching ~/scripts style) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
ITALIC='\033[3m'
NC='\033[0m'

PINK='\033[38;5;198m'
BRIGHT_PINK='\033[38;5;201m'
HOT_PINK='\033[38;5;205m'

# в”Җв”Җв”Җ Config в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
CONFIG_DIR="$HOME/.config/brewsync"
CONFIG_FILE="$CONFIG_DIR/config"
LAUNCHD_DIR="$HOME/Library/LaunchAgents"
PLIST_LABEL="com.brewsync.timer"
PLIST_FILE="$LAUNCHD_DIR/${PLIST_LABEL}.plist"

REPO_DIR=""
REMOTE_URL=""

# Resolve script's own absolute path (for embedding in plists)
SCRIPT_PATH="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)/$(basename "${BASH_SOURCE[0]}")"

# в”Җв”Җв”Җ Config persistence в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
save_config() {
  mkdir -p "$CONFIG_DIR"
  cat > "$CONFIG_FILE" <<EOF
REPO_DIR="$REPO_DIR"
REMOTE_URL="$REMOTE_URL"
EOF
}

load_config() {
  mkdir -p "$CONFIG_DIR"
  if [ -f "$CONFIG_FILE" ]; then
    source "$CONFIG_FILE"
  fi
}

# Validate config and prompt for missing/invalid values
ensure_config() {
  local needs_save=0

  # Check REPO_DIR
  if [ -z "$REPO_DIR" ] || [ ! -d "$REPO_DIR" ]; then
    if [ -n "$REPO_DIR" ] && [ ! -d "$REPO_DIR" ]; then
      echo -e "${RED}вң— Save path does not exist: ${REPO_DIR}${NC}"
    fi
    echo ""
    read -r -e -p "$(echo -e "${BRIGHT_PINK}Enter path for package lists: ~/${NC}")" repo_suffix
    clear_up 2
    if [ -z "$repo_suffix" ]; then
      echo -e "${RED}вң— No path provided. Exiting.${NC}"
      exit 1
    fi
    # Strip leading slashes/tildes from user input
    repo_suffix="${repo_suffix#/}"
    repo_suffix="${repo_suffix#\~/}"
    REPO_DIR="$HOME/$repo_suffix"
    mkdir -p "$REPO_DIR"
    if [ ! -d "$REPO_DIR/.git" ]; then
      git -C "$REPO_DIR" init
    fi
    needs_save=1
  fi

  # Check REMOTE_URL
  if [ -z "$REMOTE_URL" ]; then
    echo ""
    read -r -p "$(echo -e "${BRIGHT_PINK}Enter GitHub repo URL (https://github.com/...):${NC} ")" REMOTE_URL
    clear_up 2
    if [ -z "$REMOTE_URL" ]; then
      echo -e "${RED}вң— No repo URL provided. Exiting.${NC}"
      exit 1
    fi
    if [[ "$REMOTE_URL" != *.git ]]; then
      REMOTE_URL="${REMOTE_URL}.git"
    fi

    # Validate GitHub access
    local owner_repo
    owner_repo=$(echo "$REMOTE_URL" | sed -E 's#.*github\.com[/:]##; s#\.git$##')
    if [ -z "$owner_repo" ]; then
      echo -e "${RED}вң— Cannot parse repo from URL: ${REMOTE_URL}${NC}"
      REMOTE_URL=""
      save_config
      exit 1
    fi

    if command -v gh &>/dev/null; then
      if ! gh repo view "$owner_repo" &>/dev/null; then
        echo -e "${RED}вң— Cannot access ${owner_repo}. Run 'gh auth login' first.${NC}"
        REMOTE_URL=""
        save_config
        exit 1
      fi
    fi

    needs_save=1
  fi

  if [ "$needs_save" -eq 1 ]; then
    save_config
    echo -e "${GREEN}вң“ Configuration saved to ${CONFIG_FILE}${NC}"
    echo ""
  fi
}

# в”Җв”Җв”Җ Helper functions в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
print_header() {
  echo -e "\n${BLUE}=== $1 ===${NC}"
}

print_success() {
  echo -e "${GREEN}вң“ $1${NC}"
}

print_warning() {
  echo -e "${YELLOW}вҡ  $1${NC}"
}

print_error() {
  echo -e "${RED}вң— $1${NC}"
}

# Clear N lines above cursor (makes prompts ephemeral вҖ” next output reuses the line)
clear_up() {
  local n="${1:-1}"
  for ((i=0; i<n; i++)); do
    printf '\033[A\033[2K'
  done
  printf '\r'
}

confirm() {
  read -r -p "$1 [y/N]: " response || true
  clear_up 1
  case "$response" in
    [yY][eE][sS]|[yY]) true ;;
    *) false ;;
  esac
}

# Pad and print a line inside the cyan box (55 visible chars between в•‘ в•‘)
box_line() {
  local text="$1"
  local color="${2:-$NC}"
  local pad=$((55 - 2 - ${#text}))
  if [ "$pad" -lt 0 ]; then pad=0; fi
  printf "    ${CYAN}${ITALIC}в•‘${NC}  ${color}%s${NC}%*s${CYAN}${ITALIC}в•‘${NC}\n" "$text" "$pad" ""
}

