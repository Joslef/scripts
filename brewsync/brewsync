}

get_schedule_description() {
  if [ ! -f "$PLIST_FILE" ]; then
    echo ""
    return
  fi

  # Check for StartInterval (hourly)
  local interval
  interval=$(/usr/libexec/PlistBuddy -c "Print :StartInterval" "$PLIST_FILE" 2>/dev/null)
  if [[ "$interval" =~ ^[0-9]+$ ]]; then
    if [ "$interval" -eq 3600 ]; then
      echo "Every hour"
    else
      echo "Every $((interval / 60)) minutes"
    fi
    return
  fi

  # Check for StartCalendarInterval
  local hour minute weekday
  hour=$(/usr/libexec/PlistBuddy -c "Print :StartCalendarInterval:Hour" "$PLIST_FILE" 2>/dev/null)
  minute=$(/usr/libexec/PlistBuddy -c "Print :StartCalendarInterval:Minute" "$PLIST_FILE" 2>/dev/null)
  weekday=$(/usr/libexec/PlistBuddy -c "Print :StartCalendarInterval:Weekday" "$PLIST_FILE" 2>/dev/null)

  if [ -n "$hour" ] && [ -n "$minute" ]; then
    local time_str
    time_str=$(printf "%02d:%02d" "$hour" "$minute")
    local tz
    tz=$(date +%Z)

    if [ -n "$weekday" ]; then
      local day_name
      case "$weekday" in
        1) day_name="Monday" ;; 2) day_name="Tuesday" ;; 3) day_name="Wednesday" ;;
        4) day_name="Thursday" ;; 5) day_name="Friday" ;; 6) day_name="Saturday" ;;
        7|0) day_name="Sunday" ;;
        *) day_name="Day $weekday" ;;
      esac
      echo "Every ${day_name} at ${time_str} ${tz}"
    else
      echo "Every day at ${time_str} ${tz}"
    fi
    return
  fi

  echo "Custom schedule"
}

# Extract short repo name from URL
short_repo() {
  echo "$REMOTE_URL" | sed -E 's#.*github\.com[/:]##; s#\.git$##'
}

# в”Җв”Җв”Җ Schedule setup functions в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
setup_hourly() {
  write_plist 3600
  load_agent
  print_success "Scheduled: Every hour"
  sleep 2
}

setup_daily() {
  echo ""
  read -r -p "$(echo -e "${BRIGHT_PINK}Time to run (HH:MM, 24h format) [default 04:00]:${NC} ")" time_input
  clear_up 2
  time_input="${time_input:-04:00}"

  if ! [[ "$time_input" =~ ^([01][0-9]|2[0-3]):([0-5][0-9])$ ]]; then
    print_error "Invalid time format. Use HH:MM (e.g. 14:30)"
    sleep 2
    return
  fi

  local hour="${BASH_REMATCH[1]#0}"
  local minute="${BASH_REMATCH[2]#0}"
  local tz
  tz=$(date +%Z)

  write_plist_calendar "$hour" "$minute"
  load_agent
  echo ""
  print_success "Scheduled: Every day at ${time_input} ${tz}"
  sleep 2
}

setup_weekly() {
  echo ""
  echo -e "  ${GREEN}1)${NC} Monday"
  echo -e "  ${GREEN}2)${NC} Tuesday"
  echo -e "  ${GREEN}3)${NC} Wednesday"
  echo -e "  ${GREEN}4)${NC} Thursday"
  echo -e "  ${GREEN}5)${NC} Friday"
  echo -e "  ${GREEN}6)${NC} Saturday"
  echo -e "  ${GREEN}7)${NC} Sunday"
  echo ""
  read -r -p "$(echo -e "${BRIGHT_PINK}Select weekday [1-7]:${NC} ")" day_choice
  clear_up 10

  local day_num day_name
  case "$day_choice" in
    1) day_num=1; day_name="Monday" ;;
    2) day_num=2; day_name="Tuesday" ;;
    3) day_num=3; day_name="Wednesday" ;;
    4) day_num=4; day_name="Thursday" ;;
    5) day_num=5; day_name="Friday" ;;
    6) day_num=6; day_name="Saturday" ;;
    7) day_num=0; day_name="Sunday" ;;
    *)
      print_error "Invalid choice"
      sleep 2
      return
      ;;
  esac

  read -r -p "$(echo -e "${BRIGHT_PINK}Time to run (HH:MM, 24h format) [default 04:00]:${NC} ")" time_input
  clear_up 1
  time_input="${time_input:-04:00}"

  if ! [[ "$time_input" =~ ^([01][0-9]|2[0-3]):([0-5][0-9])$ ]]; then
    print_error "Invalid time format. Use HH:MM (e.g. 14:30)"
    sleep 2
    return
  fi

  local hour="${BASH_REMATCH[1]#0}"
  local minute="${BASH_REMATCH[2]#0}"
  local tz
  tz=$(date +%Z)

  write_plist_calendar "$hour" "$minute" "$day_num"
  load_agent
  echo ""
  print_success "Scheduled: Every ${day_name} at ${time_input} ${tz}"
  sleep 2
}

# в”Җв”Җв”Җ Change save path в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
change_path() {
  print_header "Change Save Path"
  echo -e "  Current: ${BOLD}${REPO_DIR}${NC}"
  echo ""
  read -r -e -p "$(echo -e "${BRIGHT_PINK}New path: ~/${NC}")" new_suffix
  clear_up 2

  if [ -z "$new_suffix" ]; then
    print_warning "No path entered, keeping current."
    sleep 1
    return
  fi
  new_suffix="${new_suffix#/}"
  new_suffix="${new_suffix#\~/}"
  local new_path="$HOME/$new_suffix"

  # Same path check (python3 is always present on macOS)
  local real_new real_old
  real_new=$(python3 -c "import os,sys; print(os.path.realpath(sys.argv[1]))" "$new_path")
  real_old=$(python3 -c "import os,sys; print(os.path.realpath(sys.argv[1]))" "$REPO_DIR")
  if [ "$real_new" == "$real_old" ]; then
    print_warning "Same as current path, nothing to do."
    sleep 1
    return
  fi

  local old_dir="$REPO_DIR"

  mkdir -p "$new_path"

  if [ -d "$old_dir/.git" ]; then
    cp -a "$old_dir/." "$new_path/"
    print_success "Moved repo to ${new_path}"

    echo ""
    if confirm "Delete old directory ${old_dir}?"; then
      rm -rf "$old_dir"
      print_success "Deleted ${old_dir}"
    else
      print_warning "Old directory kept at ${old_dir}"
    fi
  else
    cd "$new_path" || return
    git init
    git remote add origin "$REMOTE_URL"
    print_success "Initialized new repo at ${new_path}"
  fi

  REPO_DIR="$new_path"
  save_config
  print_success "Save path updated to: ${REPO_DIR}"
  echo ""
  read -r -p "Press Enter to continue..." && clear_up 1
}

# в”Җв”Җв”Җ Change GitHub repo в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
change_repo() {
  print_header "Change GitHub Repository"
  echo -e "  Current: ${BOLD}$(short_repo)${NC}"
  echo ""
  read -r -p "$(echo -e "${BRIGHT_PINK}GitHub repo URL (https://github.com/...):${NC} ")" new_url
  clear_up 2

  if [ -z "$new_url" ]; then
    print_warning "No URL entered, keeping current."
    sleep 1
    return
  fi

  if [[ "$new_url" != *.git ]]; then
    new_url="${new_url}.git"
  fi

  local owner_repo
  owner_repo=$(echo "$new_url" | sed -E 's#.*github\.com[/:]##; s#\.git$##')

  if [ -z "$owner_repo" ]; then
    print_error "Could not parse repository from URL."
    sleep 2
    return
  fi

  if ! command -v gh &>/dev/null; then
    print_error "gh CLI is not installed. Install it with: brew install gh"
    sleep 2
    return
  fi

  echo -e "  Checking access to ${BOLD}${owner_repo}${NC}..."
  if ! gh repo view "$owner_repo" &>/dev/null; then
    print_error "Cannot access ${owner_repo}. Are you authenticated?"
    echo -e "  Run ${BOLD}gh auth login${NC} to authenticate."
    sleep 3
    return
  fi

  REMOTE_URL="$new_url"
  save_config

  if [ -d "$REPO_DIR/.git" ]; then
    cd "$REPO_DIR" || return
    git remote set-url origin "$REMOTE_URL" 2>/dev/null || git remote add origin "$REMOTE_URL"
  fi

  print_success "Repository set to: ${owner_repo}"
  echo ""
  read -r -p "Press Enter to continue..." && clear_up 1
}

# в”Җв”Җв”Җ Restore from repo в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
do_restore() (
  cd "$REPO_DIR" || { print_error "Cannot cd to $REPO_DIR"; return 1; }

  # Ensure remote is correct and pull latest
  if ! git remote get-url origin &>/dev/null; then
    git remote add origin "$REMOTE_URL"
  else
    git remote set-url origin "$REMOTE_URL"
  fi

  echo -e "  Pulling latest from repo..."
  if ! git pull origin main --ff-only 2>/dev/null; then
    print_error "Failed to pull from remote"
    echo ""
    read -r -p "Press Enter to continue..." && clear_up 1
    return 1
  fi

  local missing_formula="" missing_cask="" missing_mas=""
  local count_formula=0 count_cask=0 count_mas=0

  # Compare formulae
  if [ -f brewlist-formula.txt ]; then
    missing_formula=$(comm -23 <(sort brewlist-formula.txt) <(brew list --formula -1 | sort))
    if [ -n "$missing_formula" ]; then
      count_formula=$(echo "$missing_formula" | wc -l | tr -d ' ')
    fi
  fi

  # Compare casks
  if [ -f brewlist-cask.txt ]; then
    missing_cask=$(comm -23 <(sort brewlist-cask.txt) <(brew list --cask -1 | sort))
    if [ -n "$missing_cask" ]; then
      count_cask=$(echo "$missing_cask" | wc -l | tr -d ' ')
    fi
  fi

  # Compare MAS apps
  if [ -f maslist.txt ] && command -v mas &>/dev/null; then
    missing_mas=$(comm -23 <(awk '{print $1}' maslist.txt | sort) <(mas list | awk '{print $1}' | sort))
    if [ -n "$missing_mas" ]; then
      count_mas=$(echo "$missing_mas" | wc -l | tr -d ' ')
    fi
  fi

  local total=$((count_formula + count_cask + count_mas))

  if [ "$total" -eq 0 ]; then
    echo ""
    print_success "All packages from repo are installed locally"
    echo ""
    read -r -p "Press Enter to continue..." && clear_up 1
    return 0
  fi

  echo ""
  echo -e "  ${BOLD}Missing packages:${NC}"
  echo ""

  if [ -n "$missing_formula" ]; then
    echo -e "  ${GREEN}Formulae (${count_formula}):${NC}"
    echo "$missing_formula" | while read -r pkg; do
      echo -e "    ${pkg}"
    done
    echo ""
  fi

  if [ -n "$missing_cask" ]; then
    echo -e "  ${GREEN}Casks (${count_cask}):${NC}"
    echo "$missing_cask" | while read -r pkg; do
      echo -e "    ${pkg}"
    done
    echo ""
  fi

  if [ -n "$missing_mas" ]; then
    echo -e "  ${GREEN}MAS apps (${count_mas}):${NC}"
    echo "$missing_mas" | while read -r app_id; do
      # Show app name from repo file if available
      local name
      name=$(grep "^${app_id} " maslist.txt | sed "s/^${app_id} //" || echo "$app_id")
      echo -e "    ${app_id} ${name}"
    done
    echo ""
  fi

  echo -e "  ${BOLD}Total: ${total} package(s) to install${NC}"
  echo ""

  read -r -p "$(echo -e "${BRIGHT_PINK}Install missing packages? [y/N]:${NC} ")" response
  case "$response" in
    [yY][eE][sS]|[yY]) ;;
    *)
      print_warning "Cancelled"
      echo ""
      read -r -p "Press Enter to continue..." && clear_up 1
      return 0
      ;;
  esac

  echo ""

  if [ -n "$missing_formula" ]; then
    echo -e "  Installing formulae..."
    echo "$missing_formula" | xargs brew install || print_error "Some formulae failed to install"
  fi

  if [ -n "$missing_cask" ]; then
    echo -e "  Installing casks..."
    echo "$missing_cask" | xargs brew install --cask || print_error "Some casks failed to install"
  fi

  if [ -n "$missing_mas" ]; then
    echo -e "  Installing MAS apps..."
    echo "$missing_mas" | xargs mas install || print_error "Some MAS apps failed to install"
  fi

  echo ""
  print_success "Restore complete"
  echo ""
  read -r -p "Press Enter to continue..." && clear_up 1
)

