#!/bin/bash

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
BOLD='\033[1m'
ITALIC='\033[3m'
NC='\033[0m'

# Fancy FF27DD color (bright magenta/pink) - ANSI 256 color
PINK='\033[38;5;198m'
BRIGHT_PINK='\033[38;5;201m'
HOT_PINK='\033[38;5;205m'

print_header() {
  echo -e "\n${BLUE}=== $1 ===${NC}"
}

print_success() {
  echo -e "${GREEN}✓ $1${NC}"
}

print_warning() {
  echo -e "${YELLOW}⚠ $1${NC}"
}

print_error() {
  echo -e "${RED}✗ $1${NC}"
}

