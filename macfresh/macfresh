print_header() {
  echo -e "\n${BLUE}=== $1 ===${NC}"
}

print_success() {
  echo -e "${GREEN}вң“ $1${NC}"
}

print_warning() {
  echo -e "${YELLOW}вҡ  $1${NC}"
}

print_error() {
