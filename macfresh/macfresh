main() {
  check_deps

  if [ "${1:-}" == "--quick" ]; then
    do_quick
    exit 0
  fi

  while true; do
    _brew_updated=false
    show_menu
    read -r -p "$(echo -e "${BRIGHT_PINK}Select option [0-9/q/a]:${NC} ")" choice || true

    case $choice in
    1) do_formulae ;;
    2) do_casks ;;
    3) do_mas ;;
    4) do_safe_update ;;
    5) do_full_update ;;
    6) do_cleanup ;;
    7) do_doctor ;;
    8) do_system_cleanup ;;
    9) do_info ;;
    q | Q)
      do_quick
      read -r -p "Press Enter to continue..." || true
      ;;
    a | A)
      do_formulae
      do_casks
      do_mas
      do_cleanup
      do_doctor
      do_system_cleanup
      do_info
      ;;
    0)
      echo -e "\n${PINK}*${NC} ${GREEN}Goodbye!${NC} ${PINK}*${NC}\n"
      exit 0
      ;;
    *)
      print_error "Invalid option"
      sleep 1
      ;;
    esac
  done
}

main "$@"
